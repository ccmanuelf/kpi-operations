# =============================================================================
# KPI Operations Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All defaults below are safe for local development (SQLite, no email, etc.).
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Runtime environment: development | staging | production
ENVIRONMENT=development

# Enable debug mode (MUST be false in production)
DEBUG=false

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Demo mode — gates demo-only startup behavior. When true, the backend
# auto-seeds demo data on boot (and may DROP ALL TABLES to refresh stale demo
# data) and self-registration is open. NEVER enable against a real database.
DEMO_MODE=false

# ---------------------------------------------------------------------------
# Database - SQLite (development / demo)
# ---------------------------------------------------------------------------
# SQLite connection string used by default. Relative paths resolve from the
# project root. No additional DB_* variables are needed for SQLite.
DATABASE_URL=sqlite:///database/kpi_platform.db

# ---------------------------------------------------------------------------
# Database - MariaDB / MySQL (production)
# ---------------------------------------------------------------------------
# For MariaDB, set DATABASE_URL to a mysql+pymysql:// URI, e.g.:
#   DATABASE_URL=mysql+pymysql://kpi_user:CHANGE_ME@localhost:3306/kpi_platform  # pragma: allowlist secret
# (The VM compose stack builds this from .env.prod values — see .env.prod.example.)

# ---------------------------------------------------------------------------
# Authentication / JWT
# ---------------------------------------------------------------------------
# Secret key for signing JWT tokens. MUST be changed in production.
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=insecure-dev-only-change-in-production

# JWT signing algorithm
ALGORITHM=HS256

# Token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins (include scheme).
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# File Uploads
# ---------------------------------------------------------------------------
# Maximum upload size in bytes (default: 10 MB)
MAX_UPLOAD_SIZE=10485760

# ---------------------------------------------------------------------------
# Email - SendGrid
# ---------------------------------------------------------------------------
# If set, SendGrid is used as the email transport.
SENDGRID_API_KEY=

# ---------------------------------------------------------------------------
# Email - SMTP (fallback when SendGrid is not configured)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
CAPACITY_PLANNING_ENABLED=true
